# New-API 数据库层环境变量模板
# 仅在数据库服务器上使用
# =============================================================================

# -----------------------------------
# PostgreSQL 配置
# -----------------------------------

# 数据库超级用户名（默认 root，与现有项目兼容）
POSTGRES_USER=root

# 数据库密码（必须设置强密码）
POSTGRES_PASSWORD=Your-Strong-DB-Password-At-Least-16-Chars!

# 数据库名
POSTGRES_DB=new-api

# -----------------------------------
# Redis 配置
# -----------------------------------

# Redis 密码（必须设置强密码）
REDIS_PASSWORD=Your-Strong-Redis-Password-At-Least-16-Chars!

# =============================================================================
# 安全提示
# =============================================================================
# 1. 此服务器必须配置防火墙，仅允许应用服务器 IP 访问以下端口：
#    - 5432 (PostgreSQL)
#    - 6379 (Redis)
#    - 26379 (Redis Sentinel)
# 2. 不要将数据库服务器直接暴露到公网
# 3. 定期执行 pg_dump 备份 PostgreSQL 数据
# 4. 定期备份 Redis AOF 文件（位于 ./redis-backups）
# =============================================================================
