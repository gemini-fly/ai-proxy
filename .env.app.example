# New-API 应用层环境变量模板（连接外部数据库）
# 仅在应用服务器上使用
# =============================================================================

# -----------------------------------
# 镜像配置
# -----------------------------------

# 镜像仓库和版本
# DOCKER_REGISTRY=ghcr.io/quantumnous
# NEW_API_VERSION=latest

# -----------------------------------
# 基础安全配置（所有实例必须一致）
# -----------------------------------

# 会话密钥：所有实例（Master + 所有 Worker）必须完全一致
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# 加密密钥（如未设置，默认使用 SESSION_SECRET）
# CRYPTO_SECRET=another-random-string

# -----------------------------------
# 数据库连接（指向独立数据库服务器）
# -----------------------------------

# 数据库服务器内网 IP（示例：192.168.1.10）
DB_HOST=192.168.1.10
DB_PORT=5432
DB_USER=root
DB_PASSWORD=Your-Strong-DB-Password-At-Least-16-Chars!
DB_NAME=new-api

# PostgreSQL 连接字符串
SQL_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable

# 日志数据库（可与主库相同）
LOG_SQL_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable

# 连接池配置（连接远程数据库建议调大）
SQL_MAX_OPEN_CONNS=500
SQL_MAX_IDLE_CONNS=100
SQL_MAX_LIFETIME=3600

# -----------------------------------
# Redis 连接（指向独立数据库服务器）
# -----------------------------------

# Redis 服务器内网 IP
REDIS_HOST=192.168.1.10
REDIS_PORT=6379
REDIS_PASSWORD=Your-Strong-Redis-Password-At-Least-16-Chars!

# Redis 连接字符串
REDIS_CONN_STRING=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# -----------------------------------
# CORS 安全配置（生产环境必须设置）
# -----------------------------------

# 允许的跨域来源
# 示例：CORS_ALLOW_ORIGINS=https://app.yourdomain.com
CORS_ALLOW_ORIGINS=

# -----------------------------------
# 高可用相关配置
# -----------------------------------

# 流式响应超时（秒）
STREAMING_TIMEOUT=300

# 关闭超时（AI 流式请求可能需要较长时间）
SHUTDOWN_TIMEOUT=5m

# 同步频率（秒）
SYNC_FREQUENCY=60

# -----------------------------------
# 可选功能配置
# -----------------------------------

# 启用调试模式（生产环境请关闭）
# DEBUG=false

# 渠道自动更新频率（秒）
# CHANNEL_UPDATE_FREQUENCY=30

# 更新任务（Midjourney / 视频任务轮询）
# UPDATE_TASK=true

# =============================================================================
# 部署检查清单
# =============================================================================
# [ ] 应用服务器能 ping 通数据库服务器
# [ ] 应用服务器能 telnet 数据库服务器 5432 端口
# [ ] 应用服务器能 telnet 数据库服务器 6379 端口
# [ ] SESSION_SECRET 与所有 Worker 实例一致
# [ ] 数据库服务器防火墙已限制仅应用服务器 IP 可访问
# =============================================================================
