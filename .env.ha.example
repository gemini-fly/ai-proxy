# New-API 高可用部署环境变量模板
# 复制为 .env 后填入实际值：cp .env.ha.example .env
# =============================================================================

# -----------------------------------
# 基础配置
# -----------------------------------

# 镜像仓库和版本（如需自建镜像仓库，请修改）
# DOCKER_REGISTRY=ghcr.io/quantumnous
# NEW_API_VERSION=latest

# 端口号（通常不需要修改，Nginx 对外暴露 80/443）
# PORT=3000

# 会话密钥：所有实例必须一致！否则 Session 会在实例间失效
# 要求：32 字节以上随机字符串，生产环境务必修改
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# 加密密钥（如未设置，默认使用 SESSION_SECRET）
# CRYPTO_SECRET=another-random-string

# -----------------------------------
# 数据库配置（PostgreSQL）
# -----------------------------------

# 数据库连接字符串（主库地址）
# 如果使用 docker-compose.ha.yml 内置 PostgreSQL：
SQL_DSN=postgres://root:your-strong-password@postgres:5432/new-api?sslmode=disable

# 日志数据库（可与主库相同，也可分离）
LOG_SQL_DSN=postgres://root:your-strong-password@postgres:5432/new-api?sslmode=disable

# PostgreSQL 密码（用于 docker-compose 启动内置数据库）
# 要求：强密码，至少 12 位，包含大小写字母、数字和特殊字符
POSTGRES_PASSWORD=Your-Strong-Postgres-Password-123!

# PostgreSQL 用户名和数据库名（通常保持默认）
# POSTGRES_USER=root
# POSTGRES_DB=new-api

# -----------------------------------
# Redis 配置
# -----------------------------------

# Redis 连接字符串
# 如果使用 docker-compose.ha.yml 内置 Redis：
REDIS_CONN_STRING=redis://:your-redis-password@redis:6379/0

# Redis 密码（用于 docker-compose 启动内置 Redis）
REDIS_PASSWORD=Your-Redis-Password-456!

# 同步频率（秒），缓存刷新间隔
# SYNC_FREQUENCY=60

# -----------------------------------
# CORS 安全配置（生产环境必须设置）
# -----------------------------------

# 允许的跨域来源，多个用逗号分隔
# 示例：CORS_ALLOW_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
# 未设置时允许所有来源但不允许携带凭据
CORS_ALLOW_ORIGINS=

# -----------------------------------
# 高可用相关配置
# -----------------------------------

# 节点类型：master 或 slave
# docker-compose.ha.yml 已自动设置，通常不需要手动修改
# NODE_TYPE=master

# 关闭超时（AI 流式请求可能需要较长时间）
# SHUTDOWN_TIMEOUT=5m

# 流式响应超时（秒）
# STREAMING_TIMEOUT=300

# -----------------------------------
# 可选功能配置
# -----------------------------------

# 启用调试模式（生产环境请关闭）
# DEBUG=false

# 启用 pprof（性能分析，生产环境建议关闭）
# ENABLE_PPROF=false

# 渠道自动更新频率（秒）
# CHANNEL_UPDATE_FREQUENCY=30

# 批量更新
# BATCH_UPDATE_ENABLED=true
# BATCH_UPDATE_INTERVAL=5

# 更新任务（Midjourney / 视频任务轮询）
# UPDATE_TASK=true

# -----------------------------------
# 支付相关配置（按需启用）
# -----------------------------------

# Stripe 密钥
# STRIPE_SECRET_KEY=sk_...

# Creem 密钥
# CREEM_SECRET_KEY=...

# 易支付配置
# EPAY_ID=...
# EPAY_KEY=...
# EPAY_URL=...

# =============================================================================
# 安全提示
# =============================================================================
# 1. 永远不要将 .env 文件提交到 Git 仓库
# 2. 所有密码必须是强密码，且与开发环境不同
# 3. 生产环境必须设置 CORS_ALLOW_ORIGINS
# 4. 建议定期轮换 SESSION_SECRET 和数据库密码
# 5. 考虑使用 Docker Secrets 或 Vault 管理敏感信息
# =============================================================================
